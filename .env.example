# ──────────────────────────────────────────────────────────
#  ParkNow — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────

# ── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (Use a hosted instance for Vercel) ──
DB_HOST=db.[PROJECT_ID].supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=[YOUR_PASSWORD]
DB_NAME=postgres
DATABASE_URL=postgresql://postgres.[PROJECT_ID]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Set to 'true' if your provider requires SSL (e.g. Aiven)
DB_SSL=false

# ── JWT ────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-64-chars
JWT_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────────────────────
FRONTEND_ORIGIN=*

# ── Vercel Specific ──────────────────────────
# Generate a random string for CRON_SECRET to secure your cron jobs
CRON_SECRET=your-cron-secret-key
