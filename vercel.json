{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/cron/(.*)",
      "destination": "backend/main.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "backend/main.py"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/frontend/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "*/5 * * * *"
    }
  ]
}
